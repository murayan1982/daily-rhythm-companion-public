# Daily Rhythm Companion backend local settings
# Copy this file to backend/.env for local development.
# Do not commit backend/.env, credentials.json, or local_data/* token files.

CONVERSATION_ENGINE=mock
SLEEP_PROVIDER=mock

# AI Character Framework local integration.
# Keep CONVERSATION_ENGINE=mock unless intentionally testing framework mode.
# Prefer FRAMEWORK_ROOT for new local setup; FRAMEWORK_PROJECT_ROOT is a legacy alias.
FRAMEWORK_ROOT=
FRAMEWORK_PROJECT_ROOT=
FRAMEWORK_PRESET=text_chat
FRAMEWORK_CHARACTER=default
FRAMEWORK_ADAPTER_MODE=local_import

# AI Character Framework text chat provider keys for strict local preflight.
# Keep blank by default. Set values only in your local operator environment or
# backend/.env when intentionally checking FW session creation.
# Never commit or paste actual values.
GOOGLE_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=

# Live text chat message execution gate.
# Keep disabled unless intentionally running the local live-message smoke.
# Day29 documents this gate but does not call ask/ask_stream yet.
DRC_FW40_ENABLE_LIVE_TEXT_CHAT_MESSAGE=0

# Bounded process-local post-advice chat lifecycle.
# Values must be positive integers; invalid values use these safe defaults.
POST_ADVICE_CHAT_TTL_SECONDS=1800
POST_ADVICE_CHAT_MAX_SESSIONS=100

# Voice input demo boundary.
# Keep disabled unless intentionally testing the v0.34.0 framework voice path.
# Supported adapter values for now:
# - disabled: safe default
# - framework: safe no-import FW checkout probe; real voice input is still not wired
VOICE_INPUT_DEMO_ENABLED=0
VOICE_INPUT_ADAPTER_MODE=disabled

# Voice output / TTS demo boundary.
# Keep disabled unless intentionally testing the v0.35.0 framework TTS path.
# Supported adapter values for now:
# - disabled: safe default
# - framework: guarded FW public voice-output boundary; requires explicit real TTS opt-in
VOICE_OUTPUT_DEMO_ENABLED=0
VOICE_OUTPUT_ADAPTER_MODE=disabled
# Keep real synthesis disabled unless intentionally collecting private operator evidence.
# DRC still sends only neutral request fields; provider-specific config stays FW-owned.
VOICE_OUTPUT_REAL_TTS_ENABLED=0
VOICE_OUTPUT_UTTERANCE_PURPOSE=demo
# DRC-owned staging/public artifact retention. Resolution does not refresh TTL.
VOICE_OUTPUT_ARTIFACT_TTL_SECONDS=86400
VOICE_OUTPUT_ARTIFACT_MAX_COUNT=100

# Live2D / VTS motion demo boundary.
# Keep disabled unless intentionally testing the v0.36.0 motion path.
# Supported adapter values for now:
# - disabled: safe default
# - framework: future FW motion adapter; not wired yet
# - vts: future VTube Studio / Live2D adapter; not wired yet
MOTION_DEMO_ENABLED=0
MOTION_DEMO_ADAPTER_MODE=disabled


# Google Health OAuth credentials
GOOGLE_HEALTH_CREDENTIALS_FILE=credentials.json
GOOGLE_HEALTH_REDIRECT_URI=http://127.0.0.1:8000/google-health/callback

# Recommended minimal scope for the current sleep flow
GOOGLE_HEALTH_OAUTH_SCOPES=https://www.googleapis.com/auth/googlehealth.sleep.readonly
GOOGLE_HEALTH_REQUIRED_SLEEP_SCOPE=https://www.googleapis.com/auth/googlehealth.sleep.readonly

# Current confirmed sleep dataPoints endpoint settings
GOOGLE_HEALTH_API_BASE_URL=https://health.googleapis.com/v4
GOOGLE_HEALTH_SLEEP_API_PATH=/users/me/dataTypes/sleep/dataPoints
GOOGLE_HEALTH_SLEEP_FILTER_QUERY_PARAM=filter
GOOGLE_HEALTH_API_TIMEOUT_SECONDS=10

# Keep real API requests OFF by default.
GOOGLE_HEALTH_ENABLE_REAL_TOKEN_EXCHANGE=0
GOOGLE_HEALTH_ENABLE_REAL_TOKEN_REFRESH=0
GOOGLE_HEALTH_ENABLE_REAL_API_REQUESTS=0
GOOGLE_HEALTH_REAL_API_OPT_IN=0
GOOGLE_HEALTH_REAL_ENDPOINT_VERIFIED=0

# Optional manual checklist flags for guarded local diagnostics.
GOOGLE_HEALTH_CLOUD_API_ENABLED_CONFIRMED=0
GOOGLE_HEALTH_OAUTH_CONSENT_SLEEP_SCOPE_CONFIRMED=0
GOOGLE_HEALTH_OAUTH_TEST_USER_CONFIRMED=0
GOOGLE_HEALTH_ENDPOINT_QUERY_CONFIRMED=0
GOOGLE_HEALTH_DATA_ACCESS_SCOPE_CONFIRMED=0
GOOGLE_HEALTH_OAUTH_PUBLISHING_STATUS_TESTING_CONFIRMED=0
GOOGLE_HEALTH_OAUTH_USER_TYPE_EXTERNAL_CONFIRMED=0
GOOGLE_HEALTH_TEST_USER_EMAIL_CONFIRMED=0
