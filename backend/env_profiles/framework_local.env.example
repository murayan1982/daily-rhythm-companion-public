# Daily Rhythm Companion - framework local profile example
#
# Copy this file to backend/.env only when intentionally testing the
# AI Character Framework integration.
#
# Do not commit backend/.env with real API keys, credentials, tokens, raw
# provider payloads, or private local paths.

# Framework mode routes /advice through the DRC conversation engine boundary.
# Keep SLEEP_PROVIDER=mock so framework tests do not depend on health data.
CONVERSATION_ENGINE=framework
SLEEP_PROVIDER=mock

# Prefer FRAMEWORK_ROOT for new local setup.
# FRAMEWORK_PROJECT_ROOT is kept as a backward-compatible alias.
# Replace the placeholder only in your local uncommitted backend/.env.
FRAMEWORK_ROOT=<path-to-ai-character-framework>
FRAMEWORK_PROJECT_ROOT=
FRAMEWORK_PRESET=text_chat
FRAMEWORK_CHARACTER=default
FRAMEWORK_ADAPTER_MODE=local_import

# Optional LLM provider keys used by AI Character Framework.
# Keep these empty unless intentionally testing real framework generation.
GEMINI_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=

# Keep real Google Health actions OFF unless this test is explicitly about them.
GOOGLE_HEALTH_ENABLE_REAL_TOKEN_EXCHANGE=0
GOOGLE_HEALTH_ENABLE_REAL_TOKEN_REFRESH=0
GOOGLE_HEALTH_ENABLE_REAL_API_REQUESTS=0
GOOGLE_HEALTH_REAL_API_OPT_IN=0
GOOGLE_HEALTH_REAL_ENDPOINT_VERIFIED=0

# Legacy Fitbit real token exchange also stays OFF for framework tests.
FITBIT_ENABLE_REAL_TOKEN_EXCHANGE=0
