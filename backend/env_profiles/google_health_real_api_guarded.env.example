# Daily Rhythm Companion - guarded real Google Health API profile example
#
# E-3 operator workflow:
# 1. Copy this file to an ignored local file:
#      backend/env_profiles/google_health_real_api_operator.local.env
# 2. Fill private/local values only in the copied *.local.env file.
# 3. Validate markers without printing values:
#      python scripts\smoke_framework_v200_real_google_health_sleep_data_preflight.py --env-file .\backend\env_profiles\google_health_real_api_operator.local.env
#
# Use only for an intentional guarded local real API test.
# Do not use this for normal development, generic API smoke tests, LLM/TTS
# provider execution, or release packaging.

CONVERSATION_ENGINE=mock
SLEEP_PROVIDER=google_health

# Local/private values. Keep the real values only in the ignored operator copy.
GOOGLE_HEALTH_CREDENTIALS_FILE=credentials.json
GOOGLE_HEALTH_EXPECTED_CLIENT_ID=
GOOGLE_HEALTH_REDIRECT_URI=http://127.0.0.1:8000/google-health/callback
GOOGLE_HEALTH_OAUTH_SCOPES=https://www.googleapis.com/auth/googlehealth.sleep.readonly
GOOGLE_HEALTH_REQUIRED_SLEEP_SCOPE=https://www.googleapis.com/auth/googlehealth.sleep.readonly

GOOGLE_HEALTH_API_BASE_URL=https://health.googleapis.com/v4
GOOGLE_HEALTH_SLEEP_API_PATH=/users/me/dataTypes/sleep/dataPoints
GOOGLE_HEALTH_SLEEP_FILTER_QUERY_PARAM=filter
GOOGLE_HEALTH_API_TIMEOUT_SECONDS=10

# All three real-request gates must be intentional.
# Token exchange is a separate OAuth step; refresh may use the stored private token.
GOOGLE_HEALTH_ENABLE_REAL_TOKEN_EXCHANGE=0
GOOGLE_HEALTH_ENABLE_REAL_TOKEN_REFRESH=1
GOOGLE_HEALTH_ENABLE_REAL_API_REQUESTS=1
GOOGLE_HEALTH_REAL_API_OPT_IN=1
GOOGLE_HEALTH_REAL_ENDPOINT_VERIFIED=1

# Optional project/access readiness confirmations. Set only after manual review.
GOOGLE_HEALTH_CLOUD_API_ENABLED_CONFIRMED=0
GOOGLE_HEALTH_OAUTH_CONSENT_SLEEP_SCOPE_CONFIRMED=0
GOOGLE_HEALTH_OAUTH_TEST_USER_CONFIRMED=0
GOOGLE_HEALTH_ENDPOINT_QUERY_CONFIRMED=0
GOOGLE_HEALTH_DATA_ACCESS_SCOPE_CONFIRMED=0
GOOGLE_HEALTH_OAUTH_PUBLISHING_STATUS_TESTING_CONFIRMED=0
GOOGLE_HEALTH_OAUTH_USER_TYPE_EXTERNAL_CONFIRMED=0
GOOGLE_HEALTH_TEST_USER_EMAIL_CONFIRMED=0

FITBIT_ENABLE_REAL_TOKEN_EXCHANGE=0
