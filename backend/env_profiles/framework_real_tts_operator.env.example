# Daily Rhythm Companion v2.0.0 private real TTS Web operator profile example
#
# Copy this file to a local-only env file when preparing the private operator
# run. Do not commit the copied file if it contains private paths or secrets.
# Provider-specific TTS configuration belongs to the AI Character Framework
# private environment, not to DRC.

# DRC should call the framework integration path.
CONVERSATION_ENGINE=framework
SLEEP_PROVIDER=mock

# Point DRC at a local checkout of AI-Character-Framework v5.0.0 or newer.
# Keep the real local value private if it includes a private absolute path.
FRAMEWORK_ROOT=<path-to-ai-character-framework>

# Real TTS Web run must use the FW v5 public voice output boundary only.
VOICE_OUTPUT_DEMO_ENABLED=1
VOICE_OUTPUT_ADAPTER_MODE=framework
VOICE_OUTPUT_REAL_TTS_ENABLED=1
VOICE_OUTPUT_UTTERANCE_PURPOSE=daily_advice

# Optional DRC/FW-neutral fields. These are labels resolved by FW, not provider
# voice IDs, API keys, provider model IDs, or provider-specific parameters.
# FRAMEWORK_PRESET=text_chat
# FRAMEWORK_CHARACTER=default

# Keep provider-specific values out of this file:
# - provider API keys
# - provider voice IDs
# - provider model IDs
# - raw provider parameters
# - raw provider payload paths
# Configure those only in the FW private environment used by the operator.
