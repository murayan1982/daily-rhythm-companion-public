# Daily Rhythm Companion - mock safe environment profile
#
# Use this profile for:
# - backend API smoke tests
# - Flutter UI checks
# - normal local development without external LLM calls
#
# This profile must not call external LLMs or real wearable APIs.

CONVERSATION_ENGINE=mock
SLEEP_PROVIDER=mock

# Keep temporary local resources bounded in normal mock-safe development.
POST_ADVICE_CHAT_TTL_SECONDS=1800
POST_ADVICE_CHAT_MAX_SESSIONS=100
VOICE_OUTPUT_ARTIFACT_TTL_SECONDS=86400
VOICE_OUTPUT_ARTIFACT_MAX_COUNT=100

# Keep external LLM keys empty for mock-safe checks.
GEMINI_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=

# Google Health OAuth/readiness defaults.
GOOGLE_HEALTH_CREDENTIALS_FILE=credentials.json
GOOGLE_HEALTH_REDIRECT_URI=http://127.0.0.1:8000/google-health/callback
GOOGLE_HEALTH_OAUTH_SCOPES=https://www.googleapis.com/auth/googlehealth.sleep.readonly
GOOGLE_HEALTH_REQUIRED_SLEEP_SCOPE=https://www.googleapis.com/auth/googlehealth.sleep.readonly

GOOGLE_HEALTH_API_BASE_URL=https://health.googleapis.com/v4
GOOGLE_HEALTH_SLEEP_API_PATH=/users/me/dataTypes/sleep/dataPoints
GOOGLE_HEALTH_SLEEP_FILTER_QUERY_PARAM=filter
GOOGLE_HEALTH_API_TIMEOUT_SECONDS=10

# Keep all real Google Health actions OFF.
GOOGLE_HEALTH_ENABLE_REAL_TOKEN_EXCHANGE=0
GOOGLE_HEALTH_ENABLE_REAL_TOKEN_REFRESH=0
GOOGLE_HEALTH_ENABLE_REAL_API_REQUESTS=0
GOOGLE_HEALTH_REAL_API_OPT_IN=0
GOOGLE_HEALTH_REAL_ENDPOINT_VERIFIED=0

# Legacy Fitbit real token exchange stays OFF.
FITBIT_ENABLE_REAL_TOKEN_EXCHANGE=0