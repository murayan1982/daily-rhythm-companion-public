# RETIRED EXECUTION PATH: legacy Fitbit Web API. Keep for migration-reference validation only.
# Do not enter real credentials or start a new OAuth connection. Use Google Health API.
# Daily Rhythm Companion v2.1.0 W-5 Fitbit operator profile template.
# Copy this file to fitbit_real_operator.local.env and fill private values there.
# The .local.env destination is ignored by Git. Never commit actual values.

CONVERSATION_ENGINE=mock
SLEEP_PROVIDER=fitbit
WEB_CORS_ORIGINS=*

# Fitbit OAuth application configuration.
FITBIT_CLIENT_ID=<fitbit-client-id>
FITBIT_CLIENT_SECRET=<fitbit-client-secret>
FITBIT_REDIRECT_URI=http://127.0.0.1:8000/fitbit/callback

# Real OAuth exchange/refresh must be an explicit operator opt-in.
FITBIT_ENABLE_REAL_TOKEN_EXCHANGE=0
FITBIT_DEV_SAVE_DUMMY_TOKEN=0
FITBIT_OAUTH_STATE_TTL_SECONDS=600

# Do not put access tokens, refresh tokens, authorization codes, OAuth state,
# raw Fitbit payloads, LLM/TTS keys, or unrelated provider credentials here.
