# Daily Rhythm Companion - FW4.0.0 configured real API profile example
#
# This file is safe for public repository use because it contains placeholders only.
# Copy this file to a private .env file and fill values locally only when
# explicitly running configured real API checks.
#
# Do not commit:
# - real API keys
# - OAuth client secrets
# - access tokens
# - refresh tokens
# - authorization headers
# - local credential files
# - raw provider payloads
# - private absolute paths

# Core configured mode
CONVERSATION_ENGINE=framework
SLEEP_PROVIDER=mock
FRAMEWORK_ROOT=<path-to-ai-character-framework>
FRAMEWORK_PROJECT_ROOT=<path-to-ai-character-framework>
FRAMEWORK_PRESET=text_chat
FRAMEWORK_CHARACTER=default
FRAMEWORK_ADAPTER_MODE=local_import

# Explicit configured real API opt-in gates
DRC_FW40_ENABLE_CONFIGURED_REAL_API_SMOKE=0
DRC_FW40_ENABLE_WEB_UI_RUNTIME_VERIFICATION=0
DRC_FW40_ENABLE_LLM_REAL_API_SMOKE=0
DRC_FW40_ENABLE_FRAMEWORK_TEXT_CHAT_SMOKE=0
DRC_FW40_ENABLE_FRAMEWORK_TEXT_CHAT_PREFLIGHT=0
DRC_FW40_ENABLE_FRAMEWORK_TEXT_CHAT_SESSION_PREFLIGHT=0
DRC_FW40_ENABLE_STT_REAL_API_SMOKE=0
DRC_FW40_ENABLE_TTS_REAL_API_SMOKE=0
DRC_FW40_ENABLE_LIVE2D_VTS_RUNTIME_SMOKE=0
DRC_FW40_ENABLE_GOOGLE_HEALTH_REAL_API_SMOKE=0

# LLM providers
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=

# TTS provider
ELEVENLABS_API_KEY=

# Google Health API
GOOGLE_HEALTH_CREDENTIALS_FILE=<private-local-credentials-file>
GOOGLE_HEALTH_ENABLE_REAL_TOKEN_EXCHANGE=0
GOOGLE_HEALTH_ENABLE_REAL_TOKEN_REFRESH=0
GOOGLE_HEALTH_ENABLE_REAL_API_REQUESTS=0
GOOGLE_HEALTH_REAL_API_OPT_IN=0
GOOGLE_HEALTH_REAL_ENDPOINT_VERIFIED=0

# Web UI runtime verification
DRC_WEB_UI_URL=http://<PC_LAN_IP>:8080
DRC_BACKEND_API_BASE_URL=http://<PC_LAN_IP>:8000
